# .env.local  ← 절대 git에 올리지 마세요!
# Supabase 프로젝트 설정 > API에서 확인

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# 서버 전용 서비스 롤 키 - 크롤러/관리자 검수 기능에 필요 (RLS 우회)
# Supabase 프로젝트 설정 > API > service_role 키
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Vercel Cron이 /api/admin/crawl(GET)을 호출할 때 사용하는 인증 시크릿
# 임의의 긴 랜덤 문자열로 설정 (Vercel 프로젝트 환경 변수에도 동일하게 등록)
CRON_SECRET=YOUR_CRON_SECRET
